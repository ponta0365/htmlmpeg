[
  {
    "id": "video_mp4_light_720p",
    "name": "MP4軽量 720p",
    "type": "video",
    "description": "互換性重視の軽量動画圧縮",
    "output_extension": ".mp4",
    "settings": {
      "overwrite": false,
      "video_codec": "libx264",
      "audio_codec": "aac",
      "crf": 28,
      "preset": "medium",
      "scale_height": 720,
      "audio_bitrate": "128k",
      "audio_stream_mode": "all",
      "subtitle_mode": "hidden"
    },
    "ffmpeg_args_template": [
      "-c:v",
      "{video_codec}",
      "-preset",
      "{preset}",
      "-crf",
      "{crf}",
      "-vf",
      "scale=-2:{scale_height}",
      "-c:a",
      "{audio_codec}",
      "-b:a",
      "{audio_bitrate}"
    ]
  },
  {
    "id": "video_h264_loudnorm_480p",
    "name": "H.264 loudnorm 480p",
    "type": "video",
    "description": "libx264 と loudnorm を使う 480p の互換性重視プリセット",
    "output_extension": ".mp4",
    "settings": {
      "overwrite": false,
      "video_codec": "libx264",
      "crf": 26,
      "scale_height": 480,
      "audio_filter": "loudnorm=I=-16:TP=-1.5:LRA=11",
      "audio_codec": "aac",
      "audio_sample_rate": 44100,
      "audio_bitrate": "128k",
      "audio_stream_mode": "all",
      "subtitle_mode": "hidden",
      "color_primaries": "bt709",
      "color_trc": "bt709",
      "colorspace": "bt709",
      "color_range": "tv",
      "pix_fmt": "yuv420p"
    },
    "ffmpeg_args_template": [
      "-c:v",
      "{video_codec}",
      "-crf",
      "{crf}",
      "-vf",
      "scale=-2:{scale_height}",
      "-af",
      "{audio_filter}",
      "-c:a",
      "{audio_codec}",
      "-ar",
      "{audio_sample_rate}",
      "-b:a",
      "{audio_bitrate}",
      "-color_primaries",
      "{color_primaries}",
      "-color_trc",
      "{color_trc}",
      "-colorspace",
      "{colorspace}",
      "-color_range",
      "{color_range}",
      "-pix_fmt",
      "{pix_fmt}"
    ]
  },
  {
    "id": "video_av1_loudnorm_bt709",
    "name": "AV1 loudnorm BT.709",
